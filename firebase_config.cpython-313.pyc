<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Certificate Verification System{% endblock %}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
</head>
<body>
    <nav class="navbar">
        <div class="container">
            <h1><i class="fas fa-shield-alt"></i> Blockchain Certificate Verification</h1>
            <div class="nav-links">
                {% if session.get('username') %}
                    {% if session.get('role') == 'admin' %}
                        <a href="{{ url_for('admin_dashboard') }}"><i class="fas fa-tachometer-alt"></i> Dashboard</a>
                    {% elif session.get('role') == 'verifier' %}
                        <a href="{{ url_for('verifier_dashboard') }}"><i class="fas fa-check-circle"></i> Verify</a>
                    {% endif %}
                    <span class="user-info">
                        <i class="fas fa-user-circle"></i> {{ session.get('username') }} 
                        <span class="role-badge role-{{ session.get('role') }}">{{ session.get('role')|upper }}</span>
                    </span>
                    <a href="{{ url_for('logout') }}" class="btn-logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
                {% endif %}
            </div>
        </div>
    </nav>

    <div class="container">
        {% with messages = get_flashed_messages() %}
            {% if messages %}
                <div class="flash-messages">
                    {% for message in messages %}
                        <div class="alert"><i class="fas fa-info-circle"></i> {{ message }}</div>
                    {% endfor %}
                </div>
            {% endif %}
        {% endwith %}

        {% block content %}{% endblock %}
    </div>

    <footer>
        <p>&copy; 2024 Blockchain Certificate Verification System</p>
    </footer>

    <script src="{{ url_for('static', filename='js/app.js') }}"></script>
</body>
</html>
