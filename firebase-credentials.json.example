from flask import Flask, render_template, request, redirect, url_for, session, flash, jsonify, send_file
import hashlib
import qrcode
import os
from datetime import datetime
from werkzeug.utils import secure_filename
from merkle_tree import MerkleTree, generate_certificate_hash
from qr_decoder import decode_qr_from_upload
from firebase_config import get_db

try:
    from web3 import Web3
    WEB3_AVAILABLE = True
except ImportError:
    WEB3_AVAILABLE = False
    Web3 = None

from config import SECRET_KEY, BLOCKCHAIN_URL, CONTRACT_ADDRESS, CONTRACT_ABI

app = Flask(__name__)
app.secret_key = SECRET_KEY

# Configure upload folder
UPLOAD_FOLDER = os.path.join(os.path.dirname(__file__), 'uploads')
ALLOWED_EXTENSIONS = {'png', 'jpg', 'jpeg', 'gif', 'bmp'}
os.makedirs(UPLOAD_FOLDER, exist_ok=True)
app.config['UPLOAD_FOLDER'] = UPLOAD_FOLDER
app.config['MAX_CONTENT_LENGTH'] = 16 * 1024 * 1024  # 16MB max file size

def allowed_file(filename):
    return '.' in filename and filename.rsplit('.', 1)[1].lower() in ALLOWED_EXTENSIONS

# Blockchain Connection
if WEB3_AVAILABLE and Web3:
    w3 = Web3(Web3.HTTPProvider(BLOCKCHAIN_URL))
    if CONTRACT_ABI and CONTRACT_ADDRESS != "0x0000000000000000000000000000000000000000":
        contract = w3.eth.contract(address=CONTRACT_ADDRESS, abi=CONTRACT_ABI)
    else:
        contract = None
else:
    w3 = None
    contract = None

# Home Route - Redirect to login
@app.route("/")
def index():
    if "role" in session:
        if session["role"] == "admin":
            return redirect(url_for("admin_dashboard"))
        elif session["role"] == "verifier":
            return redirect(url_for("verifier_dashboard"))
    return redirect(url_for("login"))

# Login Route
@app.route("/login", methods=["GET", "POST"])
def login():
    if "role" in session:
        if session["role"] == "admin":
            return redirect(url_for("admin_dashboard"))
        elif session["role"] == "verifier":
            return redirect(url_for("verifier_dashboard"))
    
    if request.method == "POST":
        username = request.form["username"]
        password = request.form["password"]
        
        db = get_db()
        if not db:
            flash("Database connection error!")
            return render_template("login.html")
        
        # Query users collection
        users_ref = db.collection('users')
        query = users_ref.where('username', '==', username).where('password', '==', password).limit(1)
        users = query.stream()
        
        user = None
        for doc in users:
            user = doc.to_dict()
            user['id'] = doc.id
            break
        
        if user:
            session["user_id"] = user["id"]
            session["username"] = user["username"]
            session["role"] = user["role"]
            
            if user["role"] == "admin":
                return redirect(url_for("admin_dashboard"))
            elif user["role"] == "verifier":
                return redirect(url_for("verifier_dashboard"))
        else:
            flash("Invalid credentials!")
    
    return render_template("login.html")

# Logout Route
@app.route("/logout")
def logout():
    session.clear()
    return redirect(url_for("index"))

# Admin Dashboard
@app.route("/admin", methods=["GET", "POST"])
def admin_dashboard():
    if "role" not in session or session["role"] != "admin":
        return redirect(url_for("login"))
    
    db = get_db()
    if not db:
        flash("Database connection error!")
        return render_template("admin-dashboard.html", certificates=[], merkle_info=None)
    
    if request.method == "POST":
        student_name = request.form["student_name"]
        course = request.form["course"]
        grade = request.form["grade"]
        
        # Generate SHA-256 hash
        cert_hash = generate_certificate_hash(student_name, course, grade)
        
        # Store in Blockchain (if configured)
        if contract:
            try:
                tx_hash = contract.functions.storeHash(cert_hash).transact({
                    "from": w3.eth.accounts[0]
                })
                w3.eth.wait_for_transaction_receipt(tx_hash)
            except Exception as e:
                flash(f"Blockchain error: {str(e)}")
        
        # Check if certificate already exists
        certs_ref = db.collection('certificates')
        existing = certs_ref.where('cert_hash', '==', cert_hash).limit(1).stream()
        
        if any(existing):
            flash("Certificate already exists!")
        else:
            # Save in Firebase
            cert_data = {
                "student_name": student_name,
                "course": course,
                "grade": grade,
                "cert_hash": cert_hash,
                "issue_date": datetime.now()
            }
            certs_ref.add(cert_data)
            
            # Rebuild Merkle Tree with all certificates
            all_certs = certs_ref.stream()
            all_hashes = [cert.to_dict()['cert_hash'] for cert in all_certs]
            
            if all_hashes:
                merkle_tree = MerkleTree(all_hashes)
                merkle_root = merkle_tree.get_root_hash()
                
                # Store Merkle root
                merkle_data = {
                    "root_hash": merkle_root,
                    "certificate_count": len(all_hashes),
                    "created_at": datetime.now()
                }
                db.collection('merkle_roots').add(merkle_data)
                
                flash(f"Merkle Root updated: {merkle_root[:16]}...")
            
            # Generate QR Code
            qr_dir = os.path.join(app.root_path, "static", "qrcodes")
            os.makedirs(qr_dir, exist_ok=True)
            img = qrcode.make(cert_hash)
            img.save(os.path.join(qr_dir, f"{cert_hash}.png"))
            
            flash(f"Certificate issued successfully! Hash: {cert_hash}")
    
    # Get all certificates
    certs_ref = db.collection('certificates').order_by('issue_date', direction='DESCENDING')
    certificates = []
    for doc in certs_ref.stream():
        cert = doc.to_dict()
        cert['id'] = doc.id
        certificates.append(cert)
    
    # Get latest Merkle root
    merkle_ref = db.collection('merkle_roots').order_by('created_at', direction='DESCENDING').limit(1)
    merkle_info = None
    for doc in merkle_ref.stream():
        merkle_info = doc.to_dict()
        break
    
    return render_template("admin-dashboard.html", certificates=certificates, merkle_info=merkle_info)

# Student Dashboard
@app.route("/student")
def student_dashboard():
    return render_template("student-dashboard.html")

# Verifier Dashboard
@app.route("/verify", methods=["GET", "POST"])
def verifier_dashboard():
    result = None
    merkle_verification = None
    
    if request.method == "POST":
        cert_hash = None
        
        # Check if QR code image is uploaded
        if 'qr_image' in request.files:
            file = request.files['qr_image']
            if file and file.filename != '' and allowed_file(file.filename):
                try:
                    cert_hash = decode_qr_from_upload(file)
                    if cert_hash:
                        flash(f"QR Code decoded successfully!")
                    else:
                        flash("Could not decode QR code from image. Please try again or enter hash manually.")
                        return render_template("verifier-dashboard.html", result=None)
                except Exception as e:
                    flash(f"Error processing QR image: {str(e)}")
                    return render_template("verifier-dashboard.html", result=None)
        
        # Check if QR code hash is provided directly
        if not cert_hash and "qr_hash" in request.form and request.form["qr_hash"]:
            cert_hash = request.form["qr_hash"].strip()
        
        # Generate hash from certificate details if no hash yet
        if not cert_hash:
            student_name = request.form.get("student_name", "")
            course = request.form.get("course", "")
            grade = request.form.get("grade", "")
            
            if not (student_name and course and grade):
                flash("Please provide QR code image, hash, or all certificate details!")
                return render_template("verifier-dashboard.html", result=None)
            
            cert_hash = generate_certificate_hash(student_name, course, grade)
        
        db = get_db()
        if not db:
            flash("Database connection error!")
            return render_template("verifier-dashboard.html", result=None)
        
        # Get all certificate hashes
        certs_ref = db.collection('certificates')
        all_certs = certs_ref.stream()
        all_hashes = [cert.to_dict()['cert_hash'] for cert in all_certs]
        
        # Get latest Merkle root
        merkle_ref = db.collection('merkle_roots').order_by('created_at', direction='DESCENDING').limit(1)
        merkle_root_info = None
        for doc in merkle_ref.stream():
            merkle_root_info = doc.to_dict()
            break
        
        merkle_verification = None
        if all_hashes:
            merkle_tree = MerkleTree(all_hashes)
            merkle_root = merkle_tree.get_root_hash()
            
            if cert_hash in all_hashes:
                proof = merkle_tree.get_proof(cert_hash)
                is_valid_merkle = merkle_tree.verify_proof(cert_hash, proof, merkle_root)
                
                merkle_verification = {
                    "valid": is_valid_merkle,
                    "root_hash": merkle_root,
                    "proof_length": len(proof),
                    "stored_root": merkle_root_info["root_hash"] if merkle_root_info else None
                }
            else:
                merkle_verification = {
                    "valid": False,
                    "root_hash": merkle_root,
                    "proof_length": 0,
                    "stored_root": merkle_root_info["root_hash"] if merkle_root_info else None
                }
        
        # Verify in Blockchain
        is_valid_blockchain = False
        if contract:
            try:
                is_valid_blockchain = contract.functions.verifyHash(cert_hash).call()
            except Exception as e:
                flash(f"Blockchain verification error: {str(e)}")
        
        # Verify in Firebase
        query = certs_ref.where('cert_hash', '==', cert_hash).limit(1)
        cert = None
        for doc in query.stream():
            cert = doc.to_dict()
            cert['id'] = doc.id
            break
        
        if cert or is_valid_blockchain:
            result = {
                "status": "valid",
                "message": "Certificate is VALID",
                "hash": cert_hash,
                "details": cert,
                "merkle": merkle_verification
            }
        else:
            result = {
                "status": "invalid",
                "message": "Certificate is INVALID",
                "hash": cert_hash,
                "merkle": merkle_verification
            }
    
    return render_template("verifier-dashboard.html", result=result)

# Delete Certificate Route
@app.route("/delete_certificate/<cert_id>", methods=["POST"])
def delete_certificate(cert_id):
    if "role" not in session or session["role"] != "admin":
        return redirect(url_for("login"))
    
    db = get_db()
    if not db:
        flash("Database connection error!")
        return redirect(url_for("admin_dashboard"))
    
    # Get certificate before deleting
    cert_ref = db.collection('certificates').document(cert_id)
    cert_doc = cert_ref.get()
    
    if cert_doc.exists:
        cert = cert_doc.to_dict()
        cert_hash = cert["cert_hash"]
        
        # Delete from Firebase
        cert_ref.delete()
        
        # Delete QR code file
        qr_path = os.path.join(app.root_path, "static", "qrcodes", f"{cert_hash}.png")
        if os.path.exists(qr_path):
            os.remove(qr_path)
        
        flash("Certificate deleted successfully!")
    else:
        flash("Certificate not found!")
    
    return redirect(url_for("admin_dashboard"))

# Download QR Code Route
@app.route("/download_qr/<cert_hash>")
def download_qr(cert_hash):
    try:
        qr_path = os.path.join(app.root_path, "static", "qrcodes", f"{cert_hash}.png")
        if os.path.exists(qr_path):
            return send_file(qr_path, as_attachment=True, download_name=f"certificate_{cert_hash[:8]}_qr.png")
        else:
            flash("QR code not found!")
            return redirect(url_for("admin_dashboard"))
    except Exception as e:
        flash(f"Error downloading QR code: {str(e)}")
        return redirect(url_for("admin_dashboard"))

if __name__ == "__main__":
    app.run(debug=True)
